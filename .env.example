# Firebase 설정 (공동지갑 실시간 동기화용)
# 이 파일을 복사해서 .env 파일을 만들고 값을 채우세요:  cp .env.example .env
# .env 는 git에 올라가지 않습니다(.gitignore).
# 값이 비어 있으면 앱은 "이 기기에만 저장"되는 로컬 모드로 동작합니다.
#
# 값 얻는 곳: Firebase 콘솔 → 프로젝트 설정 → 일반 → 내 앱 → SDK 설정 및 구성

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
